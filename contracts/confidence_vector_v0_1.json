{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/confidence_vector_v0_1.json",
  "title": "Confidence Vector V0.1",
  "type": "object",
  "required": [
    "schema_version",
    "confidence_id",
    "trace_id",
    "agent_decision_id",
    "scores"
  ],
  "properties": {
    "schema_version": { "const": "confidence_vector_v0_1" },
    "confidence_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "agent_decision_id": { "type": "string", "minLength": 1 },
    "scores": {
      "type": "object",
      "required": [
        "data_quality",
        "trace_completeness",
        "ml_signal_strength",
        "context_coverage",
        "recommendation_confidence"
      ],
      "properties": {
        "data_quality": { "type": "number", "minimum": 0, "maximum": 1 },
        "trace_completeness": { "type": "number", "minimum": 0, "maximum": 1 },
        "ml_signal_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "context_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "recommendation_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
